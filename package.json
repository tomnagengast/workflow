{
  "name": "workflow",
  "version": "0.0.3",
  "description": "Standalone runner for Claude Code dynamic workflow scripts.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "workflow": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun run scripts/build.ts",
    "release:dry-run": "bun run scripts/release/dry-run.ts",
    "release:package": "bun run scripts/release/package.ts",
    "release:cask": "bun run scripts/release/render-cask.ts",
    "context:check": "bun run dev/agent/context-check"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "dependencies": {
    "acorn": "^8.17.0"
  }
}
